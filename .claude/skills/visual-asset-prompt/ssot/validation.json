    {
      "if": [
        "Canvas",
        "Particle Field"
      ],
      "avoid": [
        "High Density",
        "Many Colors"
      ],
      "reason": "성능과 UI 가독성 저하"
    },
    {
      "if": [
        "Wellness",
        "Soft Light"
      ],
      "avoid": [
        "Glitch",
        "Cyberpunk",
        "Hard Light"
      ],
      "reason": "차분한 톤과 공격적인 오류/네온 미학이 충돌"
