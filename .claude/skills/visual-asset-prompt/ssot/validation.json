    "medium": {
      "maxKeywords": 8,
      "description": "히어로 그래픽, 다이어그램, 썸네일"
    },
    "high": {
      "maxKeywords": 12,
      "description": "복합 시스템 구조, 3D/Canvas 인터랙션"
    }
  },
  "globalIncompatibleRules": [
    {
      "if": [
        "Hairline",
        "Measurement Diagram"
      ],
      "avoid": [
        "Heavy Blur",
        "Heavy Glow"
      ],
      "reason": "정밀 선과 측정 정보가 흐려져 읽기 어려움"
    },
    {
      "if": [
        "Engraving",
        "Hatching"
      ],
      "avoid": [
        "Glass Material",
        "Mesh Gradient"
      ],
      "reason": "판화적 선 음영과 유리/그라디언트 물성이 충돌"
    },
    {
      "if": [
        "SVG Linework"
      ],
      "avoid": [
        "Photoreal Render",
        "Complex Material"
      ],
      "reason": "벡터 선화 구현과 사진/재질 중심 표현은 목표가 다름"
